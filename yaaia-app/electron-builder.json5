/**
 * @see https://www.electron.build/configuration/configuration
 * Note: files are explicit to prevent asar bloat from accidental inclusion.
 */
{
  appId: "ai.yaaia",
  productName: "YAAIA",
  directories: {
    output: "release/${version}",
  },
  files: [
    "dist",
    "dist-electron",
    "!dist-electron/resources/**",
    "!**/*.map",
    "!**/*.ts",
    "!**/*.tsbuildinfo",
    "SYSTEM_PROMPT.md",
  ],
  extraResources: [
    { from: "resources/yaaia-tg-gateway", to: "yaaia-tg-gateway" },
    // VoIP: run npm run build:telegram-gateway-voip first so resources/libntgcalls.dylib exists
    { from: "resources/libntgcalls.dylib", to: "libntgcalls.dylib" },
  ],
  asar: true,
  asarUnpack: [
    "**/node_modules/archiver/**",
    "**/node_modules/archiver-utils/**",
    "**/node_modules/zip-stream/**",
  ],
  mac: {
    icon: "resources/icon.png",
    target: [{ target: "dmg", arch: ["arm64", "x64"] }],
    artifactName: "${productName}-${version}-${arch}.${ext}",
    category: "public.app-category.developer-tools",
  },
}
