{
  "name": "yaaia",
  "version": "0.7.0",
  "description": "Yet Another AI Agent - Browser automation with Playwright CLI",
  "main": "dist-electron/main/index.js",
  "type": "module",
  "build": {
    "asar": true
  },
  "scripts": {
    "generate:api-spec": "npx tsx scripts/generate-agent-api-spec.ts",
    "migrate:history": "node scripts/migrate-history-to-mb-format.js",
    "migrate:caldav-bus-ids": "node scripts/migrate-caldav-bus-ids.js",
    "install:conda": "PYTHON=$(conda run -n yaaia-build which python) npm install && PYTHON=$(conda run -n yaaia-build which python) node node_modules/@electron/rebuild/lib/cli.js",
    "dev": "npm run generate:api-spec && electron-vite dev",
    "build": "npm run generate:api-spec && electron-vite build",
    "preview": "electron-vite preview",
    "pack": "npm run build && npm run build:vm && npm run build:ollama && mkdir -p dist-electron/resources && cp -f resources/icon.png resources/YaaiaVM dist-electron/resources/ 2>/dev/null || true && cp -rf resources/ollama dist-electron/resources/ 2>/dev/null || true && electron-builder --mac",
    "build:vm": "cd yaaia-vm && swift build -c release 2>/dev/null && cp -f .build/arm64-apple-macosx/release/YaaiaVM ../resources/ && codesign --force --sign - --entitlements YaaiaVM.entitlements ../resources/YaaiaVM || true",
    "build:ollama": "node scripts/build-ollama.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "better-sqlite3": "^12.4.2",
    "@modelcontextprotocol/sdk": "^1.27.0",
    "@mtcute/node": "^0.28.2",
    "adm-zip": "^0.5.16",
    "archiver": "^7.0.1",
    "esbuild": "^0.27.4",
    "express": "^4.21.0",
    "imapflow": "^1.2.11",
    "mailparser": "^3.9.4",
    "marked": "^17.0.2",
    "groq-sdk": "0.3.0",
    "@mistralai/mistralai": "^1.5.2",
    "@qdrant/js-client-rest": "1.13.0",
    "cloudflare": "^4.2.0",
    "redis": "^4.6.13",
    "@supabase/supabase-js": "^2.49.1",
    "@google/genai": "^1.2.0",
    "@langchain/core": "^0.3.44",
    "@azure/identity": "^4.0.0",
    "@azure/search-documents": "^12.0.0",
    "neo4j-driver": "^5.28.1",
    "otplib": "^13.3.0",
    "strip-ansi": "^7.1.0",
    "tsdav": "^2.1.8",
    "vue": "^3.4.0",
    "ws": "^8.19.0",
    "zod": "^3.23.0"
  },
  "overrides": {
    "better-sqlite3": "^12.4.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/mailparser": "^3.4.6",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-vue": "^5.0.0",
    "electron": "^40.6.0",
    "electron-builder": "^25.0.0",
    "electron-vite": "^2.0.0",
    "ts-morph": "^27.0.2",
    "tsx": "^4.21.0",
    "typescript": "^5.6.0",
    "vite": "^5.0.0",
    "vue-tsc": "^2.0.0"
  }
}
